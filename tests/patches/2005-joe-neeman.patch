 open Homespring;;
 
+(* The Unix select() syscall reports a stdin fd as "readable" when it's at
+   EOF as well as when it has actual bytes pending. The spec says the input
+   tick fires only "if any input is available" — meaning real data, not a
+   closed pipe — so we peek a byte before declaring ready. Any byte we peek
+   is kept in [buf] so subsequent reads get it back. Mixing Unix.read with
+   Stdlib's buffered stdin channel is unsafe, so we read byte-by-byte via
+   Unix.read throughout. *)
+
 class io =
-    object
+    object (self)
+    val mutable eof = false
+    val buf = Buffer.create 16
     method print s = print_string s
-    method ready =
+    method private try_read_one =
         try
-            match Unix.select [Unix.stdin] [] [] 0.0 with
-                (x::xs, [], []) -> true
-              | _ -> false
-        with
-            _ -> false
-    method get = read_line ()
+            let b = Bytes.create 1 in
+            let n = Unix.read Unix.stdin b 0 1 in
+            if n = 0 then (eof <- true; false)
+            else (Buffer.add_char buf (Bytes.get b 0); true)
+        with _ -> false
+    method ready =
+        if eof then false
+        else if Buffer.length buf > 0 then true
+        else
+            try
+                match Unix.select [Unix.stdin] [] [] 0.0 with
+                    (_::_, [], []) -> self#try_read_one
+                  | _ -> false
+            with _ -> false
+    method get =
+        let line = Buffer.create 16 in
+        let finished = ref false in
+        while not !finished do
+            if Buffer.length buf = 0 && not (self#try_read_one) then
+                finished := true
+            else begin
+                let c = Buffer.nth buf 0 in
+                let rest = Buffer.sub buf 1 (Buffer.length buf - 1) in
+                Buffer.clear buf;
+                Buffer.add_string buf rest;
+                if c = '\n' then finished := true
+                else Buffer.add_char line c
+            end
+        done;
+        Buffer.contents line
 end;;
 
+let quiet = try Sys.getenv "HS_QUIET" <> "" with Not_found -> false;;
+let report_ticks = try Sys.getenv "HS_TICKS" <> "" with Not_found -> false;;
+let tick_limit =
+    try int_of_string (Sys.getenv "HS_LIMIT")
+    with _ -> max_int;;
+
 if Array.length Sys.argv = 1 then
     print_string "error: you must supply a filename\n"
